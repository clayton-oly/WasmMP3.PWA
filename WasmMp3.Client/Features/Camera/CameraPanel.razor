@inject DeviceService Device
@inject HttpClient Http

<h1>Captura de Foto</h1>

<div class="row">
    <div class="col-md-6">
        <h5>1. Visualização em Tempo Real</h5>
        <video id="videoFeed" width="100%" style="border: 2px solid #ccc; border-radius: 8px;"></video>
        
        <button class="btn btn-primary mt-2" @onclick="IniciarCamera">Iniciar Câmera</button>
        <button class="btn btn-success mt-2" @onclick="CapturarFoto">Tirar Foto</button>
        <button class="btn btn-success mt-2" @onclick="AlternarCamera">Inverter Camêra </button>
        <button class="btn btn-success mt-2" @onclick="PararCamera">Parar </button>
    </div>

    <div class="col-md-6">
        <h5>2. Resultado (Canvas)</h5>
        <canvas id="fotoCanvas" style="display:none;"></canvas>
        
        @if (!string.IsNullOrEmpty(fotoUrl))
        {
            <img src="@fotoUrl" width="100%" style="border: 2px solid #28a745; border-radius: 8px;" />
            <a href="@fotoUrl" download="minha-foto.png" class="btn btn-info mt-2">Salvar Foto</a>

            <button class="btn btn-warning mt-2" @onclick="Upload"> Upload </button>

            @if (!string.IsNullOrEmpty(mensagem))
            {
                <div class="alert alert-sucess mt-2">@mensagem</div>
            }


        }
    </div>
</div>

@code {
    private string? fotoUrl;

    private bool cameraFrontal = true; // true para frontal, false para traseira

    private string mensagem = "";


    private async Task IniciarCamera()
    {
        await Device.StartVideoAsync("videoFeed", cameraFrontal);
    }

    private async Task CapturarFoto()
    {
        fotoUrl = await Device.TakePictureAsync("videoFeed", "fotoCanvas");
    }
    private async Task PararCamera()
    {
        await Device.StopVideoAsync("videoFeed");
    }

    private async Task AlternarCamera()
    {
        cameraFrontal = !cameraFrontal;
        await PararCamera();
        await IniciarCamera();
    }   

       private async Task Upload()
    {
        var urlApi = "https://jbn12vn3-5026.brs.devtunnels.ms";
        var response = await Http.PostAsJsonAsync(urlApi + "/api/Fotos/upload", fotoUrl);
        
        if (response.IsSuccessStatusCode)
        {
            mensagem = "Foto salva com sucesso no servidor!";
        }
        else
        {
            mensagem = "Erro ao salvar a foto.";
        }
    }

}