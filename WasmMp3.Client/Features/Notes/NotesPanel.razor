@using System.Text.Json
@inject StorageService Storage

@* vibrations *@
@inject DeviceService Device

@* Injeção do JavaScript para usar o confirm *@
@inject IJSRuntime JS


<h2 class="mb-3">Notas rápidas (Offline)</h2>

<div class="card p-3">
    <label class="form-label">Nova nota</label>

    <textarea class="form-control" rows="3" @bind="newText"></textarea>

    <div class="d-flex flex-wrap gap-2 mt-2">
        <button class="btn btn-primary" @onclick="AddNote" disabled="@string.IsNullOrWhiteSpace(newText)">
            Salvar
        </button>
        <button class="btn btn-outline-secondary" @onclick="ClearInput">
            Limpar
        </button>
        <button class="btn btn-outline-info" @onclick="Paste">Colar</button>

        <button class="btn btn-outline-warning" @onclick="GetBattery">Bateria</button>

    </div>
</div>

@if (notes.Count == 0)
{
    <p>Nenhuma nota ainda. Crie a primeira 😈</p>
}
else
{
    <div class="d-flex flex-column gap-2">
        @foreach (var n in notes.OrderByDescending(x => x.CreatedAt))
{
    <div class="card p-3">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
            
            <div class="flex-grow-1 text-break">
                <div class="small text-muted">@n.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                <div class="mt-2">@n.Text</div>
            </div>

            <div class="d-flex gap-2 mt-sm-0 mt-2">
                <button class="btn btn-sm btn-outline-danger flex-fill" @onclick="() => DeleteNote(n.Id)">
                    Excluir
                </button>
                <button class="btn btn-sm btn-outline-primary flex-fill" @onclick="() => Copy(n.Text)">
                    Copiar
                </button>
            </div>

        </div>
    </div>
}
    </div>
}

@code {
    private const string StorageKey = "wasmmp3_notes_v1";

    private string newText = "";
    private List<NoteItem> notes = new();

    protected override async Task OnInitializedAsync()
    {
        var json = await Storage.GetAsync(StorageKey);
        if (!string.IsNullOrWhiteSpace(json))
        {
            notes = JsonSerializer.Deserialize<List<NoteItem>>(json) ?? new();
        }
    }

    private async Task AddNote()
    {
        notes.Add(new NoteItem { Text = newText.Trim() });
        newText = "";
        await PersistAsync();

        //vibração curta: ação positiva (salvou)
        await Device.VibrateAsync(5000);
    }

    private void ClearInput() => newText = "";

    private async Task DeleteNote(Guid id)
{
    // 1. Pergunta ao usuário antes de fazer qualquer coisa
    bool confirmado = await JS.InvokeAsync<bool>("confirm", "Tem certeza que deseja excluir esta nota?");

    // 2. Se ele clicar em "Cancelar", paramos por aqui
    if (!confirmado) return;

    // 3. Se ele clicou em "OK", segue o fluxo normal de exclusão
    var target = notes.FirstOrDefault(x => x.Id == id);
    if (target is null) return;

    notes.Remove(target);
    await PersistAsync();
    
    // vibração um pouco mais forte: ação destrutiva (excluiu)
    await Device.VibrateAsync(5000); 
}

    private async Task PersistAsync()
    {
        var json = JsonSerializer.Serialize(notes);
        await Storage.SetAsync(StorageKey, json);
    }

    private async Task Paste()
    {
        //lendo texto do clipboard
        newText = await Device.ReadTextAsync();
    }

    private async Task Copy(string txt)
    {
        //escrevendo texto do clipboard
        await Device.CopyTextAsync(txt);
    }

    private async Task GetBattery()
    {
        var level = await Device.GetBatteryLevelAsync();

        // O script JS retorna -1 se a API não for suportada
        if (level < 0)
        {
            newText = "Não foi possível ler o nível da bateria. Ou se estiver utilizando a função no iOS, não é suportado.";
        }
        else
        {
          
            newText = $"Sua bateria está em {level:F0}%";
        }
    }

}